### Colección HTTP — IFM Services
### Base: {{baseUrl}} = http://localhost:8084/ifm
### Importar también: IFM-Services.postman_collection.json (Postman / Insomnia)

@baseUrl = http://localhost:8084/ifm
@contentType = application/json

###############################################################################
# Salud
###############################################################################

### Health — Servicio activo
GET {{baseUrl}}/test

###############################################################################
# Cuentas
###############################################################################

### 310 — Apertura de cuenta
POST {{baseUrl}}/cuentas/apertura
Content-Type: {{contentType}}

{
  "idClienteRfc": "RFC123456789",
  "fechaAperturaCuenta": "20260602",
  "horaTrx": "103000",
  "tipoPersona": "F",
  "codigoProducto": "01",
  "codigoSubproducto": "001",
  "sucursalTransaccion": "00001"
}

### 345 — Variables de cuentas
POST {{baseUrl}}/cuentas/cuentas
Content-Type: {{contentType}}

{
  "codClienteRimOrigen": "12345",
  "numeroCuentaOrigen": "000123456789",
  "codigoTransaccion": "345"
}

### 347 — Cuentas plazo fijo
POST {{baseUrl}}/cuentas/plazoFijo
Content-Type: {{contentType}}

{
  "codClienteRimOrigen": "12345",
  "numeroCuentaOrigen": "000123456789",
  "codigoTransaccion": "347"
}

### 919 — Solicitud de chequera
POST {{baseUrl}}/cuentas/solicitudChequera
Content-Type: {{contentType}}

{
  "codClienteRimOrigen": "12345",
  "numeroCuentaOrigen": "000123456789",
  "tipoChequera": "01",
  "noChequeras": 1
}

